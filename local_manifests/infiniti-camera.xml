  <!-- ==== camera-stack matrix repos: infiniti-camera-port promoted refs ==== -->

  <!-- frameworks -->
  <remove-project name="crdroidandroid/android_frameworks_av" optional="true" />
  <remove-project name="LineageOS/android_frameworks_av" optional="true" />
  <project path="frameworks/av" name="infiniti-camera-port/android_frameworks_av"
           remote="github" revision="16.0" groups="pdk,sysui-studio" />

  <remove-project name="crdroidandroid/android_frameworks_base" optional="true" />
  <remove-project name="LineageOS/android_frameworks_base" optional="true" />
  <project path="frameworks/base" name="infiniti-camera-port/android_frameworks_base"
           remote="github" revision="16.0" groups="pdk-cw-fs,pdk-fs,sysui-studio" />

  <remove-project name="crdroidandroid/android_frameworks_native" optional="true" />
  <remove-project name="LineageOS/android_frameworks_native" optional="true" />
  <project path="frameworks/native" name="infiniti-camera-port/android_frameworks_native"
           remote="github" revision="16.0" groups="pdk" />

