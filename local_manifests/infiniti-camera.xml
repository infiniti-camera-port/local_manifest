<?xml version="1.0" encoding="UTF-8"?>
<!--
  infiniti camera-port local manifest.

  Drop this file into .repo/local_manifests/ after `repo init` from
  oneplus-sm8850-development/android, then run `repo sync`.

  Re-points the camera stack at the infiniti-camera-port org.

  v4.1 build: the v4.0 composition with ONE change — vendor/oplus/camera
  pinned to 1c0fd46 (= v4.0's 4494224 + the 4-app OEM security /
  private-space bloat drop: SafeCenter, FileManager, FileEncryption,
  SecurityPermission out of the extract layer; cryptoeng App-Lock HAL +
  libOplusSecurity.so kept). All other 9 repos identical to v4.0
  (hardware/oplus branch tip e534ff5 is tree-identical to v4.0's
  f08265c1 — stub commit + revert pair).
-->
<manifest>

  <!-- frameworks -->
  <remove-project name="LineageOS/android_frameworks_av" />
  <project path="frameworks/av" name="infiniti-camera-port/android_frameworks_av"
           remote="github" revision="A16" groups="pdk,sysui-studio" />

  <remove-project name="LineageOS/android_frameworks_base" />
  <project path="frameworks/base" name="infiniti-camera-port/android_frameworks_base"
           remote="github" revision="staging/gallery-without-priv" groups="pdk-cw-fs,pdk-fs,sysui-studio" />

  <remove-project name="LineageOS/android_frameworks_native" />
  <project path="frameworks/native" name="infiniti-camera-port/android_frameworks_native"
           remote="github" revision="staging/infinityx" groups="pdk" />

  <!-- sepolicy (sm8850 vendor) -->
  <remove-project name="OnePlus-SM8850-Development/android_device_qcom_sepolicy_vndr" />
  <project path="device/qcom/sepolicy_vndr/sm8850" name="infiniti-camera-port/android_device_qcom_sepolicy_vndr"
           remote="github" revision="lineage-23.2-caf-sm8850" groups="qcom,kaanapali-vendor" />

  <!-- device trees + hardware -->
  <remove-project name="OnePlus-SM8850-Development/android_device_oneplus_infiniti" />
  <project path="device/oneplus/infiniti" name="infiniti-camera-port/android_device_oneplus_infiniti"
           remote="github" revision="staging/gallery-without-priv" />

  <remove-project name="OnePlus-SM8850-Development/android_device_oneplus_sm8850-common" />
  <project path="device/oneplus/sm8850-common" name="infiniti-camera-port/android_device_oneplus_sm8850-common"
           remote="github" revision="staging/gallery-without-priv" />

  <remove-project name="OnePlus-SM8850-Development/android_hardware_oplus" />
  <project path="hardware/oplus" name="infiniti-camera-port/android_hardware_oplus"
           remote="github" revision="staging/gallery-without-priv" />

  <!-- proprietary blobs (camera blobs landed via extraction) -->
  <remove-project name="OnePlus-SM8850-Development/proprietary_vendor_oneplus_infiniti" />
  <project path="vendor/oneplus/infiniti" name="infiniti-camera-port/proprietary_vendor_oneplus_infiniti"
           remote="github" revision="staging/gallery-without-priv" />

  <remove-project name="OnePlus-SM8850-Development/proprietary_vendor_oneplus_sm8850-common" />
  <project path="vendor/oneplus/sm8850-common" name="infiniti-camera-port/proprietary_vendor_oneplus_sm8850-common"
           remote="github" revision="lineage-23.2-infiniti" />

  <!-- oplus camera vendor (not in the base manifest; added) -->
  <project path="vendor/oplus/camera" name="infiniti-camera-port/vendor_oplus_camera"
           remote="github" revision="1c0fd4691fe0ce0392df9b66d148e53d68490c3a"
           upstream="refs/heads/staging/attest+additional" />

</manifest>
